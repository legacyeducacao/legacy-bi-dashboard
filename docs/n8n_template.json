      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO daily_trends (date, leads, investment, revenue, sales) VALUES ($1, $2, $3, $4, $5) ON CONFLICT (date) DO UPDATE SET leads = EXCLUDED.leads, investment = EXCLUDED.investment, revenue = EXCLUDED.revenue, sales = EXCLUDED.sales;",
        "additionalFields": {
          "queryParams": "={{ $json.date }}, {{ $json.leads }}, {{ $json.investment }}, {{ $json.revenue }}, {{ $json.sales }}"
        }
      },
      "id": "postgres-daily-trends",
      "name": "Update Daily Trends",
